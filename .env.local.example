# Google OAuth（GCPコンソールで取得）
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NextAuth
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your_random_secret_32chars   # openssl rand -base64 32

# 初期管理者ログイン（ID/パスワード認証のブートストラップ）
# マスタが空でもこのID/パスワードで「組合管理者」としてログインできます
BOOTSTRAP_ADMIN_ID=admin
BOOTSTRAP_ADMIN_PASSWORD=change_me_strong_password

# Googleログインを管理者にしたいメール（任意・カンマ区切り）
ADMIN_EMAILS=

# Anthropic（Claude API）
ANTHROPIC_API_KEY=your_anthropic_api_key

# 売上メール送信（Resend互換API）
RESEND_API_KEY=your_resend_api_key
# Cron保護用シークレット（任意・設定すると /api/cron/send-sales を保護）
CRON_SECRET=your_cron_secret

# Vercel KV（Vercelダッシュボードで自動設定）
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
